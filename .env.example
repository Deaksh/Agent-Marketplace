# Copy this file to `.env` at the repo root (recommended) or `backend/.env`.
# The API only loads `.env` — not `.env.example`. Never commit real tokens.

# Optional: Groq (OpenAI-compatible) for higher-quality intent parsing
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional: Hugging Face token for semantic embeddings (regulation RAG). After setting, restart the API
# and call POST /regulations/ingest/reembed to refresh vectors.
HF_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Watchtower / Beacon **origin** for POST /run (executor): scheme + host (+ port), no path.
# Paths used: /tasks/{id}, /regulations, /company/models/{id}, POST /tasks/{id}/result (optional).
# Beacon OpenAPI uses /tasks/... at the root (not /api/execution). Use a forwarded URL when cross-Codespace.
# EXECUTOR_WATCHTOWER_BASE_URL=https://xxxx-8000.app.github.dev
# Beacon may not implement POST /tasks/{id}/result yet—skip posting until the route exists:
# EXECUTOR_SKIP_RESULT_POST=true
#
# If /admin/* returns "Admin API key required", set the same key the Watchtower app expects:
# EXECUTOR_WATCHTOWER_API_KEY=your-admin-key
# EXECUTOR_WATCHTOWER_API_KEY_HEADER=X-Admin-Api-Key
#
# If curl GET /tasks/{id} returns 405, set (verify in Beacon OpenAPI):
# EXECUTOR_WATCHTOWER_TASK_HTTP_METHOD=POST

