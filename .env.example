# Copy this file to `.env` at the repo root (recommended) or `backend/.env`.
# The API only loads `.env` — not `.env.example`. Never commit real tokens.

# Optional: Groq (OpenAI-compatible) for higher-quality intent parsing
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional: Hugging Face token for semantic embeddings (regulation RAG). After setting, restart the API
# and call POST /regulations/ingest/reembed to refresh vectors.
HF_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Watchtower / Beacon base URL for POST /run (executor). Set this in **this repo’s** `.env`
# (Agent-Marketplace), not only in the Watchtower project—ExecutorSettings reads `.env` here.
# Must be reachable from the uvicorn process (same Codespace/container if using 127.0.0.1).
# EXECUTOR_WATCHTOWER_BASE_URL=http://127.0.0.1:8000/api/execution

